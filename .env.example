# Copy to .env and fill in your values (do not commit .env)

# PostgreSQL (DelayPilot storage)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_DB=delaypilot_db

# Weather (OpenWeatherMap for Munich) – optional
OPENWEATHERMAP_API_KEY=
MUNICH_CITY_ID=2861876

# Flight API (FIDS / scheduling) – optional
FLIGHT_API_BASE_URL=
FLIGHT_API_KEY=
